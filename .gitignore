# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE and OS files
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
Thumbs.db
Desktop.ini

# Runtime outputs
logs/
debug/
*.log

# Local downloaded tools/artifacts
tools/
tmp/

# Local environment files
.env
.env.*

# Model weights and large binaries
# models/*.pt
# models/*.onnx
# models/*.engine
# models/*.bin

# Keep folder structure
!models/.gitkeep
!logs/.gitkeep
!debug/.gitkeep
